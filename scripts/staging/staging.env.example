# SolarFlow staging 환경변수 (D-122)
# 실제 사용 시 staging.env 로 복사하고 secret 채워 넣을 것 (.gitignore 됨)

# 운영(prod) 과 다른 포트 — cloudflared 가 staging.topworks.ltd 를 이쪽으로 라우팅
PORT=8082

# 별도 staging DB
SUPABASE_DB_URL=postgresql://choiceoh@localhost:5432/solarflow_staging?sslmode=disable

# Supabase Auth 는 prod 와 동일 (사용자 토큰 검증만 — 데이터 격리는 아래 enforce 가 담당)
SUPABASE_URL=https://aalxpmfnsjzmhsfkuxnp.supabase.co
SUPABASE_KEY=<prod 와 동일 anon key>
SUPABASE_JWT_SECRET=<prod 와 동일>

# Rust 엔진 — staging 이 prod 와 동일 엔진 호출 (계산 결과는 결정적)
ENGINE_URL=http://localhost:18081

# 데이터 배선 enforcement 모드 (D-122)
#   off     — RequestLog 만 동작, 응답 변경 없음 (Phase 0 게이트 검증용)
#   shadow  — enforcement 실행하되 audit_log 기록만, 응답 변경 없음
#   enforce — 실제 row_filter / column_mask 적용 (Phase 1+)
# Phase 0 단계에서는 "off" 로 두고 prod 와 byte-identical 인지부터 확인
DATA_SCOPE_ENFORCE=off

# 외부 연동 비활성 — staging 에서 실데이터 외부 송신 차단 (아마란스 RPA 등)
EXTERNAL_INTEGRATIONS=off

# OCR / 첨부 등은 prod 와 같은 경로 (read-only 검증이라 안전)
