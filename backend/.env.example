SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_ANON_OR_SECRET_API_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SECRET_API_KEY_FOR_SERVER_ONLY
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET
POSTGREST_JWT_SECRET=YOUR_LOCAL_POSTGREST_JWT_SECRET
SUPABASE_DB_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
ENGINE_URL=http://127.0.0.1:8081
CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174,https://module.topworks.ltd,https://cable.topworks.ltd,https://baro.topworks.ltd

# 아마란스 웹 업로드 RPA 전용 토큰
# rpa/amaranth-uploader/.env의 SOLARFLOW_AMARANTH_RPA_TOKEN과 같은 긴 임의 문자열을 사용
SOLARFLOW_AMARANTH_RPA_TOKEN=
# 사용자용 RPA 설치 ZIP 배포 설정
SOLARFLOW_AMARANTH_RPA_PACKAGE=../rpa/amaranth-uploader/dist/solarflow-amaranth-rpa-windows.zip
SOLARFLOW_PUBLIC_API_URL=http://localhost:8080
AMARANTH_OUTBOUND_UPLOAD_URL=

# OCR (PaddleOCR/RapidOCR sidecar)
# 기본값은 backend/.venv-ocr/bin/python + backend/internal/ocr/sidecar-src/rapidocr_main.py 자동 탐색
OCR_PYTHON_BIN=
OCR_SIDECAR_SCRIPT=
OCR_REQUIRE_MODELS=0
